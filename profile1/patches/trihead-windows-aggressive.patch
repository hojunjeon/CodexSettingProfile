+    def test_cli_reads_utf8_stdin_when_process_default_is_cp949(self):
+        raw = "src/채용.py:1:fatal 합격\n"
+        proc = _run_cli(["filter", "--hint", "rg"], input_bytes=raw.encode("utf-8"))
+
+        self.assertEqual(proc.returncode, 0, proc.stderr.decode("utf-8", errors="replace"))
+        out = proc.stdout.decode("utf-8", errors="replace")
+        self.assertIn("src/채용.py:1", out)
+        self.assertIn("합격", out)
+
+    def test_run_decodes_utf8_child_output_when_process_default_is_cp949(self):
+        child = "import sys; sys.stdout.buffer.write('fatal 합격\\n'.encode()); sys.stderr.buffer.write('warning 경고\\n'.encode())"
+        proc = _run_cli(["run", "--hint", "log", "--", sys.executable, "-c", child])
+
+        self.assertEqual(proc.returncode, 0, proc.stderr.decode("utf-8", errors="replace"))
+        out = proc.stdout.decode("utf-8", errors="replace")
+        self.assertIn("fatal 합격", out)
+        self.assertIn("warning 경고", out)
+
+
+def _run_cli(args: list[str], input_bytes: bytes | None = None) -> subprocess.CompletedProcess[bytes]:
+    env = os.environ.copy()
+    env["PYTHONIOENCODING"] = "cp949"
+    env["PYTHONPATH"] = str(REPO_ROOT)
+    return subprocess.run(
+        [sys.executable, "-m", "trihead.cli", *args],
+        input=input_bytes,
+        stdout=subprocess.PIPE,
+        stderr=subprocess.PIPE,
+        cwd=REPO_ROOT,
+        env=env,
+        check=False,
+    )
+
 
